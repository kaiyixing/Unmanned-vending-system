# 本地开发配置示例
# 复制此文件为 application-local.yml 并填入实际值

spring:
  datasource:
    password: your_db_password_here
  data:
    redis:
      host: localhost

jwt:
  secret: your-256-bit-secret-key-here-must-be-at-least-256-bits

minio:
  access-key: your_minio_access_key
  secret-key: your_minio_secret_key
